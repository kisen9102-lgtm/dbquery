# =========================================================
# dbquery 配置文件示例
# 复制本文件为 .env 并填写真实值，不要提交 .env 到版本控制
# =========================================================

# Django
SECRET_KEY=your-secret-key-here-change-this
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost

# 运维数据库连接（ops_db 所在的 MySQL）
DBS_DB_HOST=localhost
DBS_DB_PORT=3306
DBS_DB_USER=ops_user
DBS_DB_PASSWORD=your-db-password
DBS_DB_NAME=ops_db
DBS_DB_CHARSET=utf8mb4

# SQL 查询默认账号
QUERY_DEFAULT_ACCOUNT=dbs_admin
QUERY_DEFAULT_PASSWORD=your-dbs-admin-password
