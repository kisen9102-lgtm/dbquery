# =========================================================
# dbquery Docker 环境配置模板
# cp .env.docker.example .env  然后修改以下值
# =========================================================

# Django
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# 外部 MySQL 连接（需自行准备 MySQL 8.0 实例）
# Docker Compose 部署时，若 MySQL 在宿主机，HOST 填 host.docker.internal
DBS_DB_HOST=host.docker.internal
DBS_DB_PORT=3306
DBS_DB_USER=ops_user
DBS_DB_PASSWORD=change-this-password
DBS_DB_NAME=ops_db
DBS_DB_CHARSET=utf8mb4

# SQL 查询账号（在各业务 MySQL / TiDB 实例上手动创建）
QUERY_DEFAULT_ACCOUNT=dbs_admin
QUERY_DEFAULT_PASSWORD=your-dbs-admin-password
