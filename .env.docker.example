# =========================================================
# dbquery Docker 环境配置模板
# cp .env.docker.example .env  然后修改以下值
# =========================================================

# Django
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL 容器连接（host 固定为 mysql，即 docker-compose 服务名）
DBS_DB_HOST=mysql
DBS_DB_PORT=3306
DBS_DB_USER=ops_user
DBS_DB_PASSWORD=Ops@2026
DBS_DB_NAME=ops_db
DBS_DB_CHARSET=utf8mb4

# MySQL root 密码（mysql 容器初始化用）
MYSQL_ROOT_PASSWORD=Root@2026

# SQL 查询账号（在各业务 MySQL 实例上手动创建）
QUERY_DEFAULT_ACCOUNT=dbs_admin
QUERY_DEFAULT_PASSWORD=your-dbs-admin-password
